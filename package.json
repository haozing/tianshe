    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "wait-on": "^8.0.1"
  },
  "private": false,
  "repository": {
    "type": "git",
