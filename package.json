    "hnswlib-node": "^3.0.0",
    "iconv-lite": "^0.7.2",
    "imghash": "^1.1.2",
    "koffi": "^2.14.1",
    "lru-cache": "^10.4.3",
    "lucide-react": "^0.454.0",
    "node-gyp-build": "^4.8.4",
    "onnxruntime-node": "^1.20.0",
    "openai": "^6.9.1",
    "p-queue": "^8.0.1",
    "pino": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.65.0",
    "sharp": "^0.33.0",
    "sonner": "^2.0.7",
    "ssim.js": "^3.5.0",
    "tailwind-merge": "^2.5.4",
