{
  "name": "@tianshe/client-open",
  "version": "1.0.0",
  "description": "Open-source Tianshe client edition",
  "author": "tiansheai",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/clean-main-dist.js && npm run build:main",
    "dev": "npm run dev:open",
    "dev:open": "node scripts/run-with-edition.js open npm run dev:base",
    "dev:base": "concurrently -k --names renderer,main,electron \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on -l http://127.0.0.1:5273 dist/main/index.js && node scripts/launch-electron.js --expose-gc .",
    "build": "npm run build:renderer && npm run build:main",
    "build:open": "node scripts/build-edition.js open",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-main-with-stamp.js",
    "test": "npm run test:open",
    "test:open": "node scripts/test-edition.js open",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "verify:open-source-boundary": "node scripts/open-source-boundary.js",
    "verify:ci": "npm run typecheck && npm run lint && npm run test:open && npm run verify:open-source-boundary && npm run build:open"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@duckdb/node-api": "^1.4.1-r.1",
    "@floating-ui/react": "^0.27.16",
    "@gutenye/ocr-node": "^1.4.0",
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "1.25.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.12",
    "adm-zip": "^0.5.16",
    "ag-grid-community": "^32.3.9",
    "ag-grid-react": "^32.3.9",
    "aho-corasick": "^0.1.3",
    "ajv": "^8.17.1",
    "async-mutex": "^0.5.0",
    "axios": "^1.7.9",
    "bytenode": "^1.5.7",
    "chokidar": "^3.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
