              }
            },
            "headers": {
              "x-airpa-api-version": {
                "$ref": "#/components/headers/XAirpaApiVersion"
              },
              "x-airpa-trace-id": {
                "$ref": "#/components/headers/XAirpaTraceId"
              }
            }
          },
          "408": {
            "description": "Invoke timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
                "$ref": "#/components/headers/XAirpaApiVersion"
