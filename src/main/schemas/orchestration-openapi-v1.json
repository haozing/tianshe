              }
            }
          },
          "429": {
            "description": "Queue overflow or rate limited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
