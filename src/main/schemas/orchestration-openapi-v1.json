      "get": {
        "tags": [
          "orchestration"
        ],
        "summary": "List orchestration capabilities",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
                "$ref": "#/components/headers/XAirpaApiVersion"
              },
              "x-airpa-trace-id": {
                "$ref": "#/components/headers/XAirpaTraceId"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
