{
  "openapi": "3.1.0",
  "info": {
    "title": "Airpa Orchestration HTTP API",
    "version": "2026-02-23",
    "description": "Stable orchestration entrypoint for external orchestrators (OpenClaw etc.). Auth is conditionally required when HTTP API enableAuth=true."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "orchestration"
    }
  ],
  "paths": {
