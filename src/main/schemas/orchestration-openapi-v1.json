  },
  "components": {
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string"
          },
          "engine": {
            "type": "string",
            "enum": [
              "electron",
              "extension"
            ]
          },
          "visible": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "InvokeRequest": {
        "type": "object",
        "required": [
          "sessionId",
          "name"
        ],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "arguments": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "required": [
          "success",
          "_meta"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "const": true
          },
          "message": {
            "type": "string"
          },
          "data": {},
          "_meta": {
            "type": "object",
            "required": [
              "traceId",
              "durationMs"
            ],
            "properties": {
              "traceId": {
                "type": "string"
              },
              "durationMs": {
                "type": "number"
              },
              "sessionId": {
                "type": "string"
              },
              "capability": {
                "type": "string"
              },
              "idempotencyKey": {
                "type": "string"
              },
              "idempotencyStatus": {
                "type": "string",
                "enum": [
                  "stored",
                  "replayed"
                ]
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "success",
          "error",
          "code",
          "_meta"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          },
          "context": {
            "type": "object",
            "additionalProperties": true
          },
          "_meta": {
            "type": "object",
            "required": [
              "traceId",
              "durationMs"
            ],
            "properties": {
              "traceId": {
                "type": "string"
              },
              "durationMs": {
                "type": "number"
              },
              "sessionId": {
                "type": "string"
              },
              "capability": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Token",
        "description": "Required when HTTP API token authentication is enabled."
      }
    },
    "headers": {
      "XAirpaApiVersion": {
        "description": "Server API contract version.",
        "schema": {
          "type": "string"
        }
      },
      "XAirpaTraceId": {
        "description": "Per-request trace id for diagnostics and support.",
        "schema": {
          "type": "string"
        }
      }
    },
    "parameters": {
      "IdempotencyKeyHeader": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": false,
        "description": "Replay key for idempotent capabilities. Same key with different payload returns 409. Backed by memory by default; optional DuckDB persistence can be enabled.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "XAirpaIdempotencyNamespaceHeader": {
        "name": "x-airpa-idempotency-namespace",
        "in": "header",
        "required": false,
        "description": "Optional idempotency namespace. Defaults to sessionId when omitted.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "XAirpaScopesHeader": {
        "name": "x-airpa-scopes",
        "in": "header",
        "required": false,
        "description": "Comma-separated scope list. Enforced only when enforceOrchestrationScopes=true.",
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    },
    {}
  ]
}
