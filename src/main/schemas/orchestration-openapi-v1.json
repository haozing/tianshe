    "/api/v1/orchestration/invoke": {
      "post": {
        "tags": [
          "orchestration"
        ],
        "summary": "Invoke capability",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKeyHeader"
          },
          {
            "$ref": "#/components/parameters/XAirpaIdempotencyNamespaceHeader"
          },
          {
            "$ref": "#/components/parameters/XAirpaScopesHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvokeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
                "$ref": "#/components/headers/XAirpaApiVersion"
              },
              "x-airpa-trace-id": {
                "$ref": "#/components/headers/XAirpaTraceId"
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {
              "x-airpa-api-version": {
                "$ref": "#/components/headers/XAirpaApiVersion"
              },
              "x-airpa-trace-id": {
                "$ref": "#/components/headers/XAirpaTraceId"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
