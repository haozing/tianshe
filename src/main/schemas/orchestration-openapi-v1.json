              "x-airpa-trace-id": {
                "$ref": "#/components/headers/XAirpaTraceId"
              }
            }
          },
          "409": {
            "description": "Idempotency key conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
