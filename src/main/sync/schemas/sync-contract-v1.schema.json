{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://airpa.local/schemas/sync-contract-v1.json",
  "title": "AIRPA Sync Contract v1",
  "description": "Non-compatible target-state sync contract schema",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/HandshakeRequest" },
    { "$ref": "#/$defs/HandshakeResponse" },
    { "$ref": "#/$defs/PushRequest" },
    { "$ref": "#/$defs/PushResponse" },
    { "$ref": "#/$defs/PullRequest" },
    { "$ref": "#/$defs/PullResponse" },
    { "$ref": "#/$defs/ArtifactUploadUrlRequest" },
    { "$ref": "#/$defs/ArtifactUploadUrlResponse" },
    { "$ref": "#/$defs/ArtifactDownloadUrlRequest" },
    { "$ref": "#/$defs/ArtifactDownloadUrlResponse" },
    { "$ref": "#/$defs/ErrorResponse" }
  ],
  "$defs": {
    "ProtocolVersion": {
      "type": "string",
      "const": "1.0"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "DateTimeString": {
      "type": "string",
      "format": "date-time"
    },
    "ScopeId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer"
        }
      ]
    },
    "ClientInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clientId", "deviceFingerprint", "appVersion"],
      "properties": {
        "clientId": { "$ref": "#/$defs/NonEmptyString" },
        "deviceFingerprint": { "$ref": "#/$defs/NonEmptyString" },
        "appVersion": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scopeType", "scopeId"],
      "properties": {
        "scopeType": { "$ref": "#/$defs/NonEmptyString" },
        "scopeId": { "$ref": "#/$defs/ScopeId" }
      }
    },
    "Domain": {
      "type": "string",
      "enum": ["account", "profile", "extension"]
    },
    "EntityType": {
      "type": "string",
      "enum": [
        "account",
        "savedSite",
        "tag",
        "profile",
        "profileGroup",
        "extensionPackage",
        "profileExtensionBinding"
      ]
    },
    "DomainVersionMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account", "profile", "extension"],
      "properties": {
        "account": { "type": "integer", "minimum": 0 },
        "profile": { "type": "integer", "minimum": 0 },
        "extension": { "type": "integer", "minimum": 0 }
      }
    },
    "DomainCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "cache", "edit", "delete"],
      "properties": {
        "view": { "type": "boolean" },
        "cache": { "type": "boolean" },
        "edit": { "type": "boolean" },
        "delete": { "type": "boolean" }
      }
    },
    "ExtensionCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "cache", "edit", "delete", "install"],
      "properties": {
        "view": { "type": "boolean" },
        "cache": { "type": "boolean" },
        "edit": { "type": "boolean" },
        "delete": { "type": "boolean" },
        "install": { "type": "boolean" }
      }
    },
    "Capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account", "profile", "extension"],
      "properties": {
        "account": { "$ref": "#/$defs/DomainCapability" },
        "profile": { "$ref": "#/$defs/DomainCapability" },
        "extension": { "$ref": "#/$defs/ExtensionCapability" }
      }
    },
    "RequestEnvelope": {
      "type": "object",
      "required": ["protocolVersion", "traceId", "client", "scope"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" }
      }
    },
    "HandshakeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "traceId", "client", "scope"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" }
      }
    },
    "HandshakeResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "traceId",
        "serverTime",
        "capabilities",
        "limits",
        "domainVersions"
      ],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "serverTime": { "$ref": "#/$defs/DateTimeString" },
        "capabilities": { "$ref": "#/$defs/Capabilities" },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxPushOps", "maxPayloadBytes", "maxArtifactBytes"],
          "properties": {
            "maxPushOps": { "type": "integer", "minimum": 1 },
            "maxPayloadBytes": { "type": "integer", "minimum": 1 },
            "maxArtifactBytes": { "type": "integer", "minimum": 1 }
          }
        },
        "domainVersions": { "$ref": "#/$defs/DomainVersionMap" }
      }
    },
    "PushEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "localId"],
      "properties": {
        "entityType": { "$ref": "#/$defs/EntityType" },
        "localId": { "$ref": "#/$defs/NonEmptyString" },
        "globalUid": { "$ref": "#/$defs/NonEmptyString" },
        "baseVersion": { "type": "integer", "minimum": 0 },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "deletedAt": {
          "anyOf": [
            { "$ref": "#/$defs/DateTimeString" },
            { "type": "null" }
          ]
        }
      }
    },
    "PushOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "opType", "eventSource", "entities"],
      "properties": {
        "domain": { "$ref": "#/$defs/Domain" },
        "opType": {
          "type": "string",
          "enum": ["upsert", "delete"]
        },
        "eventSource": {
          "type": "string",
          "enum": ["crud"]
        },
        "baseDomainVersion": { "type": "integer", "minimum": 0 },
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/PushEntity" }
        }
      }
    },
    "PushRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "traceId", "client", "scope", "idempotencyKey", "operations"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" },
        "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
        "conflictPolicy": {
          "type": "string",
          "enum": ["error", "overwrite"]
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/PushOperation" }
        }
      }
    },
    "ConflictPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serverVersion": { "type": "integer", "minimum": 0 },
        "serverContentHash": { "$ref": "#/$defs/NonEmptyString" },
        "serverEntity": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "SYNC_AUTH_REQUIRED",
        "SYNC_PERMISSION_DENIED",
        "SYNC_PROTOCOL_VERSION_UNSUPPORTED",
        "SYNC_PAYLOAD_TOO_LARGE",
        "SYNC_DOMAIN_CONFLICT",
        "SYNC_ENTITY_CONFLICT",
        "SYNC_REFERENCE_CONFLICT",
        "SYNC_ARTIFACT_NOT_FOUND",
        "SYNC_ARTIFACT_HASH_MISMATCH",
        "SYNC_SCOPE_INVALID",
        "SYNC_SECURITY_POLICY_VIOLATION",
        "SYNC_CURSOR_EXPIRED",
        "SYNC_INTERNAL_ERROR"
      ]
    },
    "PushEntityResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "localId", "status"],
      "properties": {
        "entityType": { "$ref": "#/$defs/EntityType" },
        "localId": { "$ref": "#/$defs/NonEmptyString" },
        "globalUid": { "$ref": "#/$defs/NonEmptyString" },
        "newVersion": { "type": "integer", "minimum": 0 },
        "contentHash": { "$ref": "#/$defs/NonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["ok", "conflict", "failed"]
        },
        "conflict": { "$ref": "#/$defs/ConflictPayload" },
        "errorCode": { "$ref": "#/$defs/ErrorCode" },
        "errorMessage": { "$ref": "#/$defs/NonEmptyString" },
        "message": { "$ref": "#/$defs/NonEmptyString" },
        "details": {}
      }
    },
    "PushDomainResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "newDomainVersion",
        "successCount",
        "conflictCount",
        "failureCount",
        "entityResults"
      ],
      "properties": {
        "domain": { "$ref": "#/$defs/Domain" },
        "newDomainVersion": { "type": "integer", "minimum": 0 },
        "successCount": { "type": "integer", "minimum": 0 },
        "conflictCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "entityResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/PushEntityResult" }
        }
      }
    },
    "PushResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "result", "domainResults"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "result": {
          "type": "string",
          "enum": ["success", "partial_success", "failed"]
        },
        "domainResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/PushDomainResult" }
        }
      }
    },
    "PullRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "traceId", "client", "scope", "since"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" },
        "since": { "$ref": "#/$defs/DomainVersionMap" },
        "includeDeleted": { "type": "boolean" },
        "page": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size"],
          "properties": {
            "size": { "type": "integer", "minimum": 1 },
            "cursor": { "type": "string" }
          }
        }
      }
    },
    "PullChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "globalUid", "version"],
      "properties": {
        "entityType": { "$ref": "#/$defs/EntityType" },
        "globalUid": { "$ref": "#/$defs/NonEmptyString" },
        "version": { "type": "integer", "minimum": 0 },
        "contentHash": { "$ref": "#/$defs/NonEmptyString" },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "deletedAt": {
          "anyOf": [
            { "$ref": "#/$defs/DateTimeString" },
            { "type": "null" }
          ]
        }
      }
    },
    "PullDomainResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "newDomainVersion", "changes"],
      "properties": {
        "domain": { "$ref": "#/$defs/Domain" },
        "newDomainVersion": { "type": "integer", "minimum": 0 },
        "changes": {
          "type": "array",
          "items": { "$ref": "#/$defs/PullChange" }
        }
      }
    },
    "PullResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "hasMore", "domains"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "hasMore": { "type": "boolean" },
        "nextCursor": { "type": "string" },
        "domains": {
          "type": "array",
          "items": { "$ref": "#/$defs/PullDomainResult" }
        }
      }
    },
    "ArtifactUploadUrlRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "traceId",
        "client",
        "scope",
        "artifactType",
        "sha256",
        "sizeBytes",
        "fileName"
      ],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" },
        "artifactType": {
          "type": "string",
          "const": "extension-package"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "fileName": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "ArtifactUploadUrlResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "uploadUrl", "artifactRef", "expireAt"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "uploadUrl": { "$ref": "#/$defs/NonEmptyString" },
        "artifactRef": { "$ref": "#/$defs/NonEmptyString" },
        "expireAt": { "$ref": "#/$defs/DateTimeString" }
      }
    },
    "ArtifactDownloadUrlRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "traceId", "client", "scope", "artifactRef"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "client": { "$ref": "#/$defs/ClientInfo" },
        "scope": { "$ref": "#/$defs/Scope" },
        "artifactRef": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "ArtifactDownloadUrlResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "downloadUrl", "expireAt"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "downloadUrl": { "$ref": "#/$defs/NonEmptyString" },
        "expireAt": { "$ref": "#/$defs/DateTimeString" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "error"],
      "properties": {
        "protocolVersion": { "$ref": "#/$defs/ProtocolVersion" },
        "traceId": { "$ref": "#/$defs/NonEmptyString" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "$ref": "#/$defs/ErrorCode" },
            "message": { "$ref": "#/$defs/NonEmptyString" },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
